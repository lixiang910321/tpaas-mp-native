<view class="upload-images">
  <!-- 已上传的图片列表 -->
  <view class="image-list" wx:if="{{fileList.length > 0}}">
    <view wx:for="{{fileList}}" wx:key="index" class="image-item">
      <image 
        class="image" 
        src="{{item}}" 
        mode="aspectFill" 
        bindtap="onPreviewImage"
        data-url="{{item}}"
      />
      <view class="image-delete" bindtap="onDeleteImage" data-index="{{index}}">
        <text class="delete-icon">×</text>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view 
    wx:if="{{fileList.length < maxCount}}"
    class="add-btn" 
    bindtap="onChooseImage"
  >
    <view class="add-icon">
      <text class="icon-text">+</text>
    </view>
    <text class="add-text" wx:if="{{showText}}">{{placeholder || '上传图片'}}</text>
  </view>

  <!-- 上传中提示 -->
  <view class="uploading-mask" wx:if="{{uploading}}">
    <view class="uploading-content">
      <view class="loading"></view>
      <text class="uploading-text">上传中...</text>
    </view>
  </view>
</view>
