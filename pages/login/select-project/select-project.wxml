<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-title">选择项目</view>
    <view class="header-subtitle">请选择您要进入的项目</view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载项目…</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{loadError}}" class="error-state">
    <view class="error-icon">⚠️</view>
    <text class="error-text">{{loadError}}</text>
    <button class="retry-btn" bindtap="fetchProjects">重新加载</button>
  </view>

  <!-- 项目列表 -->
  <view wx:else class="content">
    <!-- 搜索框 -->
    <view class="search-bar" wx:if="{{projects.length > 5}}">
      <view class="search-input-wrap">
        <icon type="search" size="16" color="#999"/>
        <input 
          class="search-input" 
          placeholder="搜索项目名称" 
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindclear="onSearchClear"
        />
      </view>
    </view>

    <scroll-view scroll-y class="scroll" :show-scrollbar="{{false}}">
      <!-- 空状态 -->
      <view wx:if="{{filteredList.length === 0 && !loading}}" class="empty-state">
        <view class="empty-icon">📁</view>
        <text class="empty-text">{{searchKeyword ? '未找到匹配的项目' : '该租户下暂无可进入的项目'}}</text>
      </view>

      <!-- 项目列表项 -->
      <view 
        wx:for="{{filteredList}}"
        wx:key="id"
        wx:for-item="item"
        class="project-item {{item.selected ? 'project-item--active' : ''}}"
        bindtap="onSelectProject"
        data-index="{{index}}"
        data-project="{{item}}"
        hover-class="project-item--hover"
        hover-stay-time="100"
      >
        <view class="project-content">
          <view class="project-name">{{item.name || item.code || '项目 ' + item.id}}</view>
          <view class="project-code" wx:if="{{item.code}}">编号: {{item.code}}</view>
        </view>
        <view class="radio {{item.selected ? 'radio--checked' : ''}}">
          <view wx:if="{{item.selected}}" class="radio-dot"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部确认按钮 -->
  <view class="footer safe-bottom">
    <button 
      class="confirm-btn {{selectedId ? 'confirm-btn--active' : ''}}" 
      disabled="{{submitting || loading || loadError || !selectedId}}"
      loading="{{submitting}}"
      bindtap="onConfirm"
    >
      {{submitting ? '登录中...' : '确定'}}
    </button>
  </view>
</view>
