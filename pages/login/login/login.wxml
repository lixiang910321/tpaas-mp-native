<view class="page">
  <view class="brand">
    <image class="logo" src="/static/login/logo.png" mode="widthFix" />
    <text class="app-name">蜻蜓维保</text>
  </view>

  <view class="form">
    <view class="field">
      <image class="field-icon" src="/static/login/icon-phone.svg" mode="aspectFit" />
      <view class="field-main">
        <text class="field-label">手机号</text>
        <input
          value="{{userName}}"
          bindinput="onUserNameInput"
          class="field-input"
          type="text"
          maxlength="32"
          placeholder="请输入"
          placeholder-class="field-ph"
        />
      </view>
    </view>
    <view class="divider" />

    <view class="field">
      <image class="field-icon" src="/static/login/icon-lock.svg" mode="aspectFit" />
      <view class="field-main">
        <text class="field-label">密码</text>
        <input
          value="{{password}}"
          bindinput="onPasswordInput"
          class="field-input"
          password
          maxlength="64"
          placeholder="请输入"
          placeholder-class="field-ph"
        />
      </view>
    </view>
    <view class="divider" />
  </view>

  <button class="submit" type="default" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">
    登录
  </button>
</view>
