.page {
  min-height: 100vh;
  padding: 48rpx 48rpx 80rpx;
  box-sizing: border-box;
  background-color: #ffffff;
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
  margin-bottom: 72rpx;
}

.logo {
  width: 420rpx;
  max-width: 86vw;
}

.app-name {
  margin-top: 28rpx;
  font-size: 48rpx;
  color: #000000;
  font-weight: 500;
}

.form {
  margin-bottom: 48rpx;
}

.field {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 0 24rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.field-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.field-main {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.field-label {
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
}

.field-ph {
  color: #cccccc;
  font-size: 28rpx;
}

.divider {
  height: 1px;
  background-color: rgba(0, 0, 0, 0.08);
  margin-left: 56rpx;
}

.submit {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 56rpx;
  height: 100rpx;
  line-height: 1;
  text-align: center;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%) !important;
  color: #ffffff !important;
  font-size: 32rpx;
  font-weight: 400;
  border: none;
}

.submit::after {
  border: none;
}
