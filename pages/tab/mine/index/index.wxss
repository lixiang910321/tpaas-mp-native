.page {
  min-height: 100%;
  background-color: #f5f6fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #8b7cff 0%, #7467ef 100%);
  margin-bottom: 24rpx;
}

.avatar-wrap {
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.avatar-text {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 600;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 48rpx;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 36rpx;
}

/* 分区 */
.section {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  padding: 24rpx 32rpx 16rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

/* 当前项目卡片 */
.project-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 28rpx;
}

.project-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.project-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.project-detail {
  flex: 1;
  min-width: 0;
}

.project-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-code {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 36rpx;
}

.project-empty {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.switch-btn {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #7467ef;
  font-weight: 500;
}

.switch-arrow {
  font-size: 36rpx;
  color: #7467ef;
  margin-left: 4rpx;
  line-height: 1;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 28rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-top: 1rpx solid #f5f5f5;
}

.menu-item:first-child {
  border-top: none;
}

.menu-label {
  font-size: 32rpx;
  color: #333;
}

.menu-label--danger {
  color: #ff4d4f;
}

.menu-arrow {
  font-size: 40rpx;
  color: #bbb;
  line-height: 1;
}
