<view class="page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.realName ? userInfo.realName[0] : (userInfo.userName ? userInfo.userName[0] : '?')}}</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.realName || userInfo.userName || '未知用户'}}</text>
      <text class="user-id" wx:if="{{userInfo.userName}}">账号：{{userInfo.userName}}</text>
    </view>
  </view>

  <!-- 当前项目 -->
  <view class="section">
    <view class="section-title">当前项目</view>
    <view class="project-card" bindtap="onSwitchProject">
      <view class="project-info">
        <view class="project-icon">🏗️</view>
        <view class="project-detail">
          <text class="project-name" wx:if="{{currentProject}}">{{currentProject.name || currentProject.code || ('项目 ' + currentProject.id)}}</text>
          <text class="project-name" wx:if="{{!currentProject}}">未选择项目</text>
          <text class="project-code" wx:if="{{currentProject && currentProject.code}}">{{currentProject.code}}</text>
        </view>
      </view>
      <view class="switch-btn">
        <text class="switch-text">切换</text>
        <text class="switch-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 租户信息 -->
  <view class="section" wx:if="{{currentTenant}}">
    <view class="section-title">租户</view>
    <view class="info-row">
      <text class="info-label">租户名称</text>
      <text class="info-value">{{currentTenant.name || '—'}}</text>
    </view>
  </view>

  <!-- 操作区 -->
  <view class="section">
    <view class="menu-item" bindtap="onMyTasks">
      <text class="menu-label">我的任务</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item menu-item--danger" bindtap="onLogout">
      <text class="menu-label menu-label--danger">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
