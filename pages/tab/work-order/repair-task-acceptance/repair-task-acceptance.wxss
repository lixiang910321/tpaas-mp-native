.page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.scroll {
  height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.state-card {
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  margin: 24rpx;
}

.state-text {
  font-size: 28rpx;
  color: #333333;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 24rpx;
  overflow: hidden;
}

.section {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section:last-child {
  border-bottom: none;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.picker-value {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.value-text {
  font-size: 28rpx;
  color: #333333;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  font-size: 36rpx;
  color: #999999;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.actions {
  padding: 32rpx 24rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}
