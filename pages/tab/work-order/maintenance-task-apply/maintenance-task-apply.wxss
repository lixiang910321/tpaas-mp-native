/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.loading-container {
  padding: 80rpx 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #969799;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  margin: 24rpx;
  border-radius: 12rpx;
  padding: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.card-action {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 28rpx;
  color: #7b68ee;
}

.change-text {
  color: #ff9900;
}

.arrow {
  font-size: 32rpx;
  color: #c8c9cc;
  margin-left: 8rpx;
}

/* 空状态 */
.empty-row {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #c8c9cc;
}

/* 已选列表 */
.selected-list,
.selected-iot {
  margin-top: 16rpx;
}

.selected-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.selected-item:last-child {
  margin-bottom: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #323233;
  display: block;
  margin-bottom: 8rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #969799;
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.delete-icon {
  font-size: 40rpx;
  color: #ee0a24;
  font-weight: bold;
}

/* 人员选择 */
.personnel-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.personnel-section:last-of-type {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.personnel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.personnel-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.personnel-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.personnel-label {
  font-size: 28rpx;
  color: #323233;
}

.personnel-type-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.personnel-type {
  font-size: 28rpx;
  color: #646566;
}

.personnel-required {
  font-size: 24rpx;
  color: #7b68ee;
}

.personnel-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.person-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.person-info {
  flex: 1;
}

.person-name {
  font-size: 28rpx;
  color: #323233;
}

.person-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.delete-icon {
  font-size: 40rpx;
  color: #ee0a24;
  font-weight: bold;
}

.person-add {
  width: 96rpx;
  height: 96rpx;
  border: 2rpx dashed #7b68ee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #7b68ee;
  line-height: 1;
}

.add-line-btn {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #ebedf0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-line-icon {
  font-size: 32rpx;
  color: #7b68ee;
  margin-right: 8rpx;
}

.add-line-text {
  font-size: 28rpx;
  color: #7b68ee;
}

/* 机械选择 */
.machine-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.machine-label {
  font-size: 28rpx;
  color: #323233;
}

.machine-value-row {
  display: flex;
  align-items: center;
}

.machine-value {
  font-size: 28rpx;
  color: #323233;
}

.machine-value.placeholder {
  color: #c8c9cc;
}

/* 物联设备 */
.iot-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.iot-label {
  font-size: 28rpx;
  color: #323233;
}

.iot-value-row {
  display: flex;
  align-items: center;
}

.iot-value {
  font-size: 28rpx;
  color: #323233;
}

.iot-value.placeholder {
  color: #c8c9cc;
}

/* 提交按钮 */
.actions {
  padding: 32rpx 24rpx;
  padding-top: 24rpx;
}

.btn-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  line-height: 1;
  text-align: center;
  border-radius: 8rpx;
  background: #7b68ee;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  background: #b8a9f5;
  color: #fff;
}
