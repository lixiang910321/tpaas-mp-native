.page {
  min-height: 100%;
  background-color: #f8f8f8;
}

.scroll {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-card {
  margin: 24rpx;
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.state-card.err {
  background: #fff3f0;
}

.state-text {
  font-size: 28rpx;
  color: #333333;
}

.detail-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  background: linear-gradient(90deg, #f5f3ff 0%, #faf8ff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.header-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  color: #666666;
}

.header-status.status-completed {
  background: #e6f7ed;
  color: #04ab38;
}

.header-status.status-reported {
  background: #f0f2ff;
  color: #7467ef;
}

.header-status.status-applied {
  background: #fff3e0;
  color: #ff9800;
}

.card-body {
  padding: 28rpx;
}

.section-title {
  padding: 24rpx 28rpx 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
}

.section-title:first-of-type {
  border-top: none;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

.action-card {
  padding: 32rpx 0;
}

.btn-primary {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after {
  border: none;
}
