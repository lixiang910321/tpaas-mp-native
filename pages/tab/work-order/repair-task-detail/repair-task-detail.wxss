.page {
  min-height: 100%;
  background-color: #f8f8f8;
}

.scroll {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-card {
  margin: 24rpx;
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.state-card.err {
  background: #fff3f0;
}

.state-text {
  font-size: 28rpx;
  color: #333333;
}

.detail-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  background: linear-gradient(90deg, #f5f3ff 0%, #faf8ff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.header-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  color: #666666;
}

.header-status.status-completed {
  background: #e6f7ed;
  color: #04ab38;
}

.header-status.status-reported {
  background: #f0f2ff;
  color: #7467ef;
}

.header-status.status-applied {
  background: #fff3e0;
  color: #ff9800;
}

.card-body {
  padding: 28rpx;
}

.section-title {
  padding: 24rpx 28rpx 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
}

.section-title:first-of-type {
  border-top: none;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}
.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 横向滚动图片列表 */
.image-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 12rpx;
}
.image-list-horizontal {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}
.image-item-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-card {
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-success {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #2ed573 0%, #04ab38 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-success::after {
  border: none;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #333333;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 人员标签 */
.personnel-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.personnel-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}
.personnel-name {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 物料网格 */
.material-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 12rpx;
}
.material-card {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(252, 182, 159, 0.3);
}
.material-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.material-card .material-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}
.material-card .material-qty {
  font-size: 24rpx;
  color: #666666;
}
