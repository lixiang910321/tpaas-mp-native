<view class="page">
  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>
  <view wx:elif="{{error}}" class="state-card err">
    <text class="state-text">{{error}}</text>
  </view>
  <scroll-view wx:else scroll-y class="scroll">
    <view class="detail-card">
      <view class="card-header">
        <text class="header-title">维修任务详情</text>
        <text class="header-status {{getStatusClass(task.status)}}">{{getStatusText(task.status)}}</text>
      </view>
      
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">任务类型</text>
          <text class="info-value">维修</text>
        </view>
        <view class="info-row">
          <text class="info-label">任务编号</text>
          <text class="info-value">{{task.taskNo || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">令号</text>
          <text class="info-value">{{task.cmdNum || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">区域</text>
          <text class="info-value">{{task.areaName || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.confirmEmployeeName}}">
          <text class="info-label">驻站值班员</text>
          <text class="info-value">{{task.confirmEmployeeName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.confirmTime}}">
          <text class="info-label">确认时间</text>
          <text class="info-value">{{task.confirmTime}}</text>
        </view>
      </view>
    </view>

    <!-- 病害项点信息 -->
    <view class="detail-card">
      <view class="card-header">
        <text class="header-title">计划项点信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">项点名称</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.name || task.planProjectPointName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">故障类型</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.faultTypeName || task.faultTypeName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">故障等级</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.faultLevelName || task.faultLevel || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">严重程度</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.severityDegreeName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">预计耗时</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.timeConsumed ? task.diseaseProjectPointDetail.timeConsumed + '小时' : (task.estimatedHours ? task.estimatedHours + '小时' : '-')}}</text>
        </view>
        <view class="info-row" wx:if="{{task.diseaseProjectPointDetail && task.diseaseProjectPointDetail.windowTimeName}}">
          <text class="info-label">窗口时间</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.windowTimeName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">安全交底</text>
          <text class="info-value">{{task.diseaseProjectPointDetail.safetyDisclosureName || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- 实际项点信息 -->
    <view class="detail-card" wx:if="{{task.actualProjectPointName || task.actualProjectPointDetail}}">
      <view class="card-header">
        <text class="header-title">实际项点信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">项点名称</text>
          <text class="info-value">{{task.actualProjectPointDetail.name || task.actualProjectPointName || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail}}">
          <text class="info-label">故障类型</text>
          <text class="info-value">{{task.actualProjectPointDetail.faultTypeName || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail}}">
          <text class="info-label">故障等级</text>
          <text class="info-value">{{task.actualProjectPointDetail.faultLevelName || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail}}">
          <text class="info-label">严重程度</text>
          <text class="info-value">{{task.actualProjectPointDetail.severityDegreeName || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail}}">
          <text class="info-label">预计耗时</text>
          <text class="info-value">{{task.actualProjectPointDetail.timeConsumed ? task.actualProjectPointDetail.timeConsumed + '小时' : '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail && task.actualProjectPointDetail.windowTimeName}}">
          <text class="info-label">窗口时间</text>
          <text class="info-value">{{task.actualProjectPointDetail.windowTimeName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualProjectPointDetail}}">
          <text class="info-label">安全交底</text>
          <text class="info-value">{{task.actualProjectPointDetail.safetyDisclosureName || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- 确认信息 -->
    <view class="detail-card">
      <view class="card-header">
        <text class="header-title">确认信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">施工类别</text>
          <text class="info-value">{{task.constructionCategoryName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">确认人</text>
          <text class="info-value">{{task.confirmEmployeeName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">确认时间</text>
          <text class="info-value">{{task.confirmTime || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{task.confirmRemark}}">
          <text class="info-label">确认备注</text>
          <text class="info-value">{{task.confirmRemark}}</text>
        </view>
      </view>
    </view>

    <!-- 申请信息 -->
    <view class="detail-card" wx:if="{{task.applyEmployeeName || task.applyTime || task.applyRemark}}">
      <view class="card-header">
        <text class="header-title">申请信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">申请人</text>
          <text class="info-value">{{task.applyEmployeeName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">申请时间</text>
          <text class="info-value">{{task.applyTime || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">申请备注</text>
          <text class="info-value">{{task.applyRemark}}</text>
        </view>
      </view>
    </view>

    <!-- 提报信息 -->
    <view class="detail-card" wx:if="{{task.reportEmployeeName || task.reportTime || task.repairResult}}">
      <view class="card-header">
        <text class="header-title">提报信息</text>
      </view>
      <view class="card-body">
        <view class="info-row" wx:if="{{task.actualAreaName}}">
          <text class="info-label">实际区域</text>
          <text class="info-value">{{task.actualAreaName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.actualConstructionCategoryName}}">
          <text class="info-label">实际施工类别</text>
          <text class="info-value">{{task.actualConstructionCategoryName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.repairResult}}">
          <text class="info-label">维修结果</text>
          <text class="info-value">{{task.repairResult === 10 ? '已修复' : task.repairResult === 20 ? '未修复' : task.repairResult}}</text>
        </view>
        <view class="info-row" wx:if="{{task.unrepairReason}}">
          <text class="info-label">未修复原因</text>
          <text class="info-value">{{task.unrepairReason}}</text>
        </view>
        <view class="info-row" wx:if="{{task.reportEmployeeName}}">
          <text class="info-label">提报人</text>
          <text class="info-value">{{task.reportEmployeeName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.reportTime}}">
          <text class="info-label">提报时间</text>
          <text class="info-value">{{formatTime(task.reportTime)}}</text>
        </view>
        <view class="info-row-vertical" wx:if="{{task.completionPhotoUrls}}">
          <text class="info-label">完工照片</text>
          <scroll-view scroll-x class="image-scroll">
            <view class="image-list-horizontal">
              <image wx:for="{{task.completionPhotoUrls}}" wx:key="index" class="image-item-small" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
            </view>
          </scroll-view>
        </view>
        <view class="info-row" wx:if="{{task.repairRemark}}">  
          <text class="info-label">提报备注</text>
          <text class="info-value">{{task.repairRemark}}</text>
        </view>
        <view class="info-row-vertical" wx:if="{{task.reportPersonnelList && task.reportPersonnelList.length > 0}}">
          <text class="info-label">维修人员</text>
          <view class="personnel-tags">
            <view wx:for="{{task.reportPersonnelList}}" wx:key="index" class="personnel-tag">
              <text class="personnel-name">{{item.laborerName}}</text>
            </view>
          </view>
        </view>
        <view class="info-row-vertical" wx:if="{{task.reportMaterialList && task.reportMaterialList.length > 0}}">
          <text class="info-label">使用物料</text>
          <view class="material-grid">
            <view wx:for="{{task.reportMaterialList}}" wx:key="index" class="material-card">
              <view class="material-info">
                <text class="material-name">{{item.materialName}}</text>
                <text class="material-qty">{{item.quantity}} {{item.unit || '个'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 验收信息 -->
    <view class="detail-card" wx:if="{{task.acceptanceResultName || task.acceptanceEmployeeName || task.acceptanceTime}}">
      <view class="card-header">
        <text class="header-title">验收信息</text>
      </view>
      <view class="card-body">
        <view class="info-row" wx:if="{{task.repairMethodName}}">
          <text class="info-label">维修方式</text>
          <text class="info-value">{{task.repairMethodName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.acceptanceResultName}}">
          <text class="info-label">验收结果</text>
          <text class="info-value">{{task.acceptanceResultName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.acceptanceRemark}}">
          <text class="info-label">验收备注</text>
          <text class="info-value">{{task.acceptanceRemark}}</text>
        </view>
        <view class="info-row" wx:if="{{task.acceptanceEmployeeName}}">
          <text class="info-label">验收人</text>
          <text class="info-value">{{task.acceptanceEmployeeName}}</text>
        </view>
        <view class="info-row" wx:if="{{task.acceptanceTime}}">
          <text class="info-label">验收时间</text>
          <text class="info-value">{{task.acceptanceTime}}</text>
        </view>
        <view class="info-row-vertical" wx:if="{{task.acceptancePhotoUrls}}">
          <text class="info-label">验收照片</text>
          <scroll-view scroll-x class="image-scroll">
            <view class="image-list-horizontal">
              <image wx:for="{{task.acceptancePhotoUrls}}" wx:key="index" class="image-item-small" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
            </view>
          </scroll-view>
        </view>
      </view>
    </view>

    <!-- 根据状态显示不同操作 -->
    <view wx:if="{{task.status === 30}}" class="action-card">
      <button class="btn-primary" bindtap="onApply">去申请执行</button>
    </view>
    <view wx:elif="{{task.status === 40}}" class="action-card">
      <button class="btn-primary" bindtap="onReport">去提报</button>
    </view>
    <view wx:elif="{{task.status === 50 && isConfirmEmployee}}" class="action-card">
      <button class="btn-success" bindtap="onAccept">验收通过</button>
      <button class="btn-secondary" bindtap="onReport">重新提报</button>
    </view>
  </scroll-view>
</view>
