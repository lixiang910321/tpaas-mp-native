<view class="page">
  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>
  <view wx:elif="{{list.length === 0}}" class="state-card">
    <text class="state-text">暂无工单</text>
  </view>
  <view wx:else class="card-list">
    <view wx:for="{{list}}" wx:key="id" class="wo-card">
      <view class="wo-rows">
        <view class="wo-row">
          <text class="wo-label">工单编号</text>
          <text class="wo-val wo-val-strong">{{item.orderNo || '-'}}</text>
        </view>
        <view class="wo-row">
          <text class="wo-label">工单状态</text>
          <text class="wo-val wo-val-strong">{{item.statusText}}</text>
        </view>
        <view class="wo-row">
          <text class="wo-label">创建时间</text>
          <text class="wo-val wo-val-strong">{{item.createTime || '-'}}</text>
        </view>
        <view class="wo-row">
          <text class="wo-label">任务数量</text>
          <text class="wo-val wo-val-strong">{{item.taskCount != null ? item.taskCount : '-'}}</text>
        </view>
      </view>
      <view class="wo-footer" bindtap="onDetail" data-item="{{item}}">
        <text class="wo-detail">查看详情</text>
        <text class="wo-chevron">›</text>
      </view>
    </view>
  </view>
</view>
