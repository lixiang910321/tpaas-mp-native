.page {
  min-height: 100%;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background-color: #f8f8f8;
}

.filters-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(116, 103, 239, 0.1);
  box-sizing: border-box;
}

.filters {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-input {
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.filter-placeholder {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.4;
}

.filter-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.search-wrap {
  padding: 0;
}

.filter-search {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333333;
}

.filter-ph {
  color: #999999;
  font-size: 28rpx;
}

.state-card {
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.state-text {
  display: block;
  font-size: 30rpx;
  color: #333333;
}

.state-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.wo-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(116, 103, 239, 0.08);
}

.wo-rows {
  padding: 28rpx 28rpx 8rpx;
}

.wo-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 24rpx;
}

.wo-label {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 400;
  color: #000000;
}

.wo-val {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  text-align: right;
  word-break: break-all;
}

.wo-val-strong {
  font-weight: 600;
}

.st-green {
  color: #04ab38;
}

.st-purple {
  color: #7467ef;
}

.st-normal {
  color: #000000;
}

.wo-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 28rpx 24rpx;
  border-top: 1px solid #eeeeee;
}

.wo-detail {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.wo-chevron {
  margin-left: 8rpx;
  font-size: 36rpx;
  font-weight: 400;
  color: #999999;
  line-height: 1;
}
