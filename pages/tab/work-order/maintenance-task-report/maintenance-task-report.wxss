.page { min-height: 100%; background-color: #f5f5f5; }
.scroll { height: 100vh; padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }
.state-card { padding: 48rpx 32rpx; background: #ffffff; border-radius: 16rpx; text-align: center; margin: 24rpx; }
.state-text { font-size: 28rpx; color: #333333; }
.form-card { background: #ffffff; border-radius: 16rpx; margin: 24rpx; overflow: hidden; }
.section { padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.section:last-child { border-bottom: none; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333333; margin-bottom: 24rpx; display: block; }
.info-row { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.info-label { font-size: 28rpx; color: #666666; }
.info-value { font-size: 28rpx; color: #333333; font-weight: 500; }
.form-item { margin-bottom: 32rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label { font-size: 28rpx; color: #333333; margin-bottom: 16rpx; display: block; }
.picker-value { height: 88rpx; padding: 0 24rpx; background: #f5f5f5; border-radius: 12rpx; display: flex; align-items: center; justify-content: space-between; }
.value-text { font-size: 28rpx; color: #333333; }
.placeholder-text { font-size: 28rpx; color: #999999; }
.arrow { font-size: 36rpx; color: #999999; }
.form-textarea { width: 100%; min-height: 200rpx; padding: 20rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }

/* 完成量 */
.quantity-row { display: flex; align-items: center; }
.quantity-input { flex: 1; height: 88rpx; padding: 0 24rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; }
.quantity-unit { margin-left: 16rpx; font-size: 28rpx; color: #666; }

/* 物料 */
.empty-hint { padding: 32rpx 0; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; }
.material-list { margin-bottom: 24rpx; }
.material-item { background: #f9f9f9; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; }
.material-info { margin-bottom: 16rpx; }
.material-name { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.material-spec { font-size: 24rpx; color: #999; }
.material-row { display: flex; align-items: center; }
.material-label { font-size: 26rpx; color: #666; margin-right: 16rpx; }
.material-input { flex: 1; height: 64rpx; padding: 0 16rpx; background: #fff; border-radius: 8rpx; font-size: 26rpx; }
.material-unit { margin: 0 16rpx; font-size: 26rpx; color: #666; }
.material-delete { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.delete-icon { font-size: 40rpx; color: #ee0a24; font-weight: bold; }
.select-btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border: 2rpx dashed #4caf50; border-radius: 12rpx; }
.select-icon { font-size: 40rpx; color: #4caf50; margin-right: 8rpx; }
.select-text { font-size: 28rpx; color: #4caf50; }

.actions { padding: 32rpx 24rpx; }
.btn-primary { height: 96rpx; line-height: 96rpx; border-radius: 16rpx; background: linear-gradient(180deg, #66bb6a 0%, #4caf50 100%); color: #fff; font-size: 32rpx; font-weight: 500; border: none; margin-bottom: 24rpx; }
.btn-primary::after { border: none; }
.btn-default { height: 96rpx; line-height: 96rpx; border-radius: 16rpx; background: #f5f5f5; color: #666; font-size: 32rpx; border: none; }
.btn-default::after { border: none; }
