.page {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 160rpx;
  display: flex;
  flex-direction: column;
}

/* 面包屑导航 */
.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  overflow-x: auto;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.breadcrumb::-webkit-scrollbar {
  display: none;
}

.breadcrumb-item {
  font-size: 26rpx;
  color: #969799;
  white-space: nowrap;
  flex-shrink: 0;
}

.breadcrumb-item.active {
  color: #7b68ee;
  font-weight: 500;
}

.breadcrumb-sep {
  margin: 0 8rpx;
  color: #c8c9cc;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 区域列表 */
.scroll {
  flex: 1;
  overflow-y: auto;
}

.list {
  padding: 16rpx 24rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
}

.item-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f0f0ff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 32rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #323233;
  display: block;
}

.item-desc {
  font-size: 24rpx;
  color: #969799;
  margin-top: 6rpx;
  display: block;
}

/* 选中勾 */
.item-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.check-icon {
  font-size: 36rpx;
  color: #7b68ee;
  font-weight: bold;
}

/* 状态 */
.state-card {
  padding: 100rpx 32rpx;
  text-align: center;
  background: #fff;
  margin: 24rpx;
  border-radius: 12rpx;
}

.state-text {
  font-size: 28rpx;
  color: #969799;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-confirm {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
  background: #7b68ee;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm[disabled] {
  background: #c8c9cc;
  color: #fff;
}
