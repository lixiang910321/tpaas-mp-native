<view class="page">
  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索项点名称" placeholder-class="search-ph" />
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{list.length === 0}}" class="state-card">
    <text class="state-text">暂无项点</text>
  </view>

  <scroll-view wx:else scroll-y class="scroll">
    <view class="list">
      <view wx:for="{{list}}" wx:key="id" class="item" bindtap="onSelect" data-item="{{item}}">
        <view class="item-icon">
          <text class="icon-text">📋</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.name || '-'}}</text>
          <text class="item-type">{{item.projectPointType === 1 ? '维修' : item.projectPointType === 2 ? '维保' : '未知'}}</text>
        </view>
        <view class="item-radio">
          <view class="radio {{selectedId === item.id ? 'radio-checked' : ''}}">
            <view wx:if="{{selectedId === item.id}}" class="radio-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer" wx:if="{{selectedId}}">
    <button class="btn-confirm" bindtap="onConfirm">确认选择</button>
  </view>
</view>
