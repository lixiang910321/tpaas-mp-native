<view class="page">
  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索员工姓名" placeholder-class="search-ph" />
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{list.length === 0}}" class="state-card">
    <text class="state-text">暂无员工</text>
  </view>

  <scroll-view wx:else scroll-y class="scroll">
    <view class="list">
      <view wx:for="{{list}}" wx:key="id" class="item" bindtap="onSelect" data-item="{{item}}">
        <view class="item-avatar">
          <text class="avatar-text">{{item.name ? item.name.charAt(0) : '?'}}</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.name || '-'}}</text>
          <text class="item-phone">{{item.phone || '未绑定手机号'}}</text>
        </view>
        <view class="item-check">
          <text wx:if="{{selectedId === item.id}}" class="check-icon">✓</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
