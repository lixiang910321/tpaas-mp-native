.page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.scroll {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-card {
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  margin: 24rpx;
}

.state-text {
  font-size: 28rpx;
  color: #333333;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.form-item.required .form-label::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.picker-value {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.value-text {
  font-size: 28rpx;
  color: #333333;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  font-size: 36rpx;
  color: #999999;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.actions {
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 24rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-default {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #666666;
  font-size: 32rpx;
  border: none;
  text-align: center;
}

.btn-default::after {
  border: none;
}

/* 计划项点卡片（参照维保任务详情） */
.detail-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  background: linear-gradient(90deg, #e8f5e9 0%, #f1f8e9 100%);
  border-bottom: 1rpx solid #f0f0f0;
}
.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}
.card-body {
  padding: 28rpx;
}
.card-body .info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-body .info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.card-body .info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 400;
  text-align: right;
  flex: 1;
}

/* 垂直布局信息行 */
.info-row-vertical {
  margin-bottom: 24rpx;
}
.info-row-vertical:last-child {
  margin-bottom: 0;
}
.info-row-vertical .info-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

/* 人员标签 */
.personnel-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.personnel-tag {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
  flex-shrink: 0;
}
.personnel-name {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 物料网格 */
.material-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 12rpx;
}
.material-card {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(252, 182, 159, 0.3);
}
.material-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.material-card .material-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}
.material-card .material-qty {
  font-size: 24rpx;
  color: #666666;
}
