.page {
  min-height: 100%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.header-left,
.header-right {
  width: 120rpx;
}

.header-right {
  text-align: right;
}

.cancel-text {
  font-size: 28rpx;
  color: #666666;
}

.confirm-text {
  font-size: 28rpx;
  color: #7467ef;
  font-weight: 500;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  gap: 16rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.clear-icon {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: #7467ef;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 列表 */
.list {
  flex: 1;
  padding: 24rpx 32rpx;
}

.loading,
.empty {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.item:active {
  transform: scale(0.98);
}

.item.active {
  background: #f5f3ff;
  border: 2rpx solid #7467ef;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.item-code {
  font-size: 24rpx;
  color: #999999;
}

.item-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24rpx;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: #7467ef;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
}

.loading-more,
.no-more {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
}
