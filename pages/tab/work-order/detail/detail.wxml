<view class="page">
  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>
  <view wx:elif="{{error}}" class="state-card err">
    <text class="state-text">{{error}}</text>
  </view>
  <scroll-view wx:else scroll-y class="scroll" :show-scrollbar="{{false}}">
    <view wx:if="{{tasks.length === 0}}" class="state-card slim">
      <text class="state-text">暂无任务</text>
    </view>
    <view wx:else class="task-list">
      <view wx:for="{{tasks}}" wx:key="taskId" class="task-card">
        <view class="task-body">
          <view class="kv-row">
            <text class="kv-label">任务编号</text>
            <text class="kv-val kv-val-strong">{{item.taskNo || '-'}}</text>
          </view>
          <view class="kv-row">
            <text class="kv-label">创建时间</text>
            <text class="kv-val kv-val-strong">{{item.createTime || '-'}}</text>
          </view>
          <view class="kv-row">
            <text class="kv-label">任务类型</text>
            <text class="kv-val kv-val-strong">{{item.taskTypeName || '-'}}</text>
          </view>
          <view class="kv-row">
            <text class="kv-label">任务状态</text>
            <text class="kv-val kv-val-strong">{{item.statusName || '-'}}</text>
          </view>
          <view class="kv-row" wx:if="{{item.areaName}}">
            <text class="kv-label">区域</text>
            <text class="kv-val">{{item.areaName}}</text>
          </view>
          <view class="kv-row">
            <text class="kv-label">项点</text>
            <text class="kv-val">{{item.projectPointName || '-'}}</text>
          </view>
          <view class="kv-row" wx:if="{{item.faultTypeName}}">
            <text class="kv-label">故障类型</text>
            <text class="kv-val">{{item.faultTypeName}}</text>
          </view>
          <view class="kv-row" wx:if="{{item.faultLevelName}}">
            <text class="kv-label">故障等级</text>
            <text class="kv-val">{{item.faultLevelName}}</text>
          </view>
          <view class="kv-row" wx:if="{{item.severityDegreeName}}">
            <text class="kv-label">严重程度</text>
            <text class="kv-val">{{item.severityDegreeName}}</text>
          </view>
        </view>
        <view class="task-footer" bindtap="onTaskDetail" data-item="{{item}}">
          <text class="task-detail-text">查看详情</text>
          <text class="task-chevron">›</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
