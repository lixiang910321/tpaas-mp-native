<view class="page">
  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>
  <scroll-view wx:else scroll-y class="scroll">
    <view class="form-card">
      <!-- 任务信息 -->
      <view class="section">
        <text class="section-title">任务信息</text>
        <view class="info-row">
          <text class="info-label">区域</text>
          <text class="info-value">{{task.areaName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">作业项点</text>
          <text class="info-value">{{task.projectPointName || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">故障类型</text>
          <text class="info-value">{{task.faultTypeName || '-'}}</text>
        </view>
      </view>

      <!-- 维修结果 -->
      <view class="section">
        <text class="section-title">维修结果</text>
        <view class="form-item">
          <text class="form-label">维修结果</text>
          <picker mode="selector" range="{{repairResultOptions}}" range-key="name" bindchange="onRepairResultChange" value="{{form.repairResultId}}">
            <view class="picker-value">
              <text wx:if="{{form.repairResult}}" class="value-text">{{form.repairResult}}</text>
              <text wx:else class="placeholder-text">请选择维修结果</text>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>
        
        <!-- 未修复原因 -->
        <view wx:if="{{form.repairResultId === 20}}" class="form-item">
          <text class="form-label">未修复原因</text>
          <textarea class="form-textarea" value="{{form.unfixReason}}" bindinput="onUnfixReasonInput" placeholder="请填写未修复原因" maxlength="500" />
        </view>
      </view>

      <!-- 施工类别 -->
      <view class="section">
        <text class="section-title">施工信息</text>
        <view class="form-item">
          <text class="form-label">施工类别</text>
          <picker mode="selector" range="{{constructionCategoryOptions}}" range-key="name" bindchange="onConstructionCategoryChange" value="{{form.constructionCategoryId}}">
            <view class="picker-value">
              <text wx:if="{{form.constructionCategoryName}}" class="value-text">{{form.constructionCategoryName}}</text>
              <text wx:else class="placeholder-text">请选择施工类别</text>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 实际项点 -->
      <view class="section">
        <text class="section-title">实际项点</text>
        <view class="form-item" bindtap="onSelectActualProjectPoint">
          <text class="form-label">项点</text>
          <view class="picker-value">
            <text wx:if="{{form.actualProjectPointName}}" class="value-text">{{form.actualProjectPointName}}</text>
            <text wx:else class="placeholder-text">请选择实际项点</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 维修人员 -->
      <view class="section">
        <text class="section-title">维修人员</text>
        <view wx:if="{{form.repairLaborers.length === 0}}" class="empty-hint">
          <text class="empty-text">请选择维修人员</text>
        </view>
        <view wx:else class="laborer-list">
          <view wx:for="{{form.repairLaborers}}" wx:key="id" class="laborer-item">
            <view class="laborer-info">
              <text class="laborer-name">{{item.name}}</text>
              <text wx:if="{{item.workTypeName}}" class="laborer-type">{{item.workTypeName}}</text>
            </view>
            <view class="laborer-delete" bindtap="onDeleteRepairLaborer" data-index="{{index}}">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </view>
        <view class="select-btn" bindtap="onSelectRepairLaborer">
          <text class="select-icon">+</text>
          <text class="select-text">选择维修人员</text>
        </view>
      </view>

      <!-- 物料 -->
      <view class="section">
        <text class="section-title">物料</text>
        <view wx:if="{{form.materialLines.length === 0}}" class="empty-hint">
          <text class="empty-text">请选择物料</text>
        </view>
        <view wx:else class="material-list">
          <view wx:for="{{form.materialLines}}" wx:key="id" class="material-item">
            <view class="material-info">
              <text class="material-name">{{item.categoryName || item.name}}</text>
              <text wx:if="{{item.modelSpec}}" class="material-spec">{{item.modelSpec}}</text>
            </view>
            <view class="material-row">
              <text class="material-label">数量</text>
              <input class="material-input" type="number" value="{{item.quantity}}" bindinput="onMaterialQuantityInput" data-index="{{index}}" placeholder="填写数量" placeholder-class="input-placeholder" />
              <text class="material-unit">{{item.unit || '个'}}</text>
              <view class="material-delete" bindtap="onDeleteMaterial" data-index="{{index}}">
                <text class="delete-icon">×</text>
              </view>
            </view>
          </view>
        </view>
        <view class="select-btn" bindtap="onSelectMaterial">
          <text class="select-icon">+</text>
          <text class="select-text">选择物料</text>
        </view>
      </view>

      <!-- 完工图片 -->
      <view class="section">
        <text class="section-title">完工图片</text>
        <upload-images 
          fileList="{{form.completionPhotos}}"
          max-count="9"
          placeholder="上传完工图片"
          bind:change="onCompletionPhotosChange"
        />
      </view>

      <!-- 提报备注 -->
      <view class="section">
        <text class="section-title">提报备注</text>
        <textarea class="form-textarea" value="{{form.submitRemark}}" bindinput="onSubmitRemarkInput" placeholder="请填写提报备注" maxlength="500" />
      </view>
    </view>

    <view class="actions">
      <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">提交提报</button>
      <button class="btn-default" bindtap="onCancel">取消</button>
    </view>
  </scroll-view>
</view>
