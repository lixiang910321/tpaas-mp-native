.page {
  min-height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  background-color: #f8f8f8;
}

.filters-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(116, 103, 239, 0.1);
}

.filters {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-input {
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.filter-placeholder {
  font-size: 28rpx;
  color: #999999;
}

.filter-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.state-card {
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.state-text {
  font-size: 30rpx;
  color: #333333;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.task-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(116, 103, 239, 0.08);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(90deg, #f5f3ff 0%, #faf8ff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.task-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  color: #666666;
}

.task-status.status-completed {
  background: #e6f7ed;
  color: #04ab38;
}

.task-status.status-reported {
  background: #f0f2ff;
  color: #7467ef;
}

.task-body {
  padding: 28rpx;
}

.task-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.task-row:last-child {
  margin-bottom: 0;
}

.task-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.task-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

.fault-level {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #fff3e0;
  color: #ff9800;
}

.task-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
}

.task-action {
  font-size: 28rpx;
  color: #7467ef;
  font-weight: 500;
}

.task-arrow {
  margin-left: 8rpx;
  font-size: 36rpx;
  color: #999999;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 28rpx;
}
