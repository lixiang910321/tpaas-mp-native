<view class="page">
  <!-- Tab 切换 -->
  <view class="tabs">
    <view
      class="tab-item {{activeTab === 0 ? 'tab-active' : ''}}"
      data-idx="0"
      bindtap="onTabChange"
    >
      <text class="tab-text">待验收</text>
      <view class="tab-line" wx:if="{{activeTab === 0}}"></view>
    </view>
    <view
      class="tab-item {{activeTab === 1 ? 'tab-active' : ''}}"
      data-idx="1"
      bindtap="onTabChange"
    >
      <text class="tab-text">已验收</text>
      <view class="tab-line" wx:if="{{activeTab === 1}}"></view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="state-card">
    <text class="state-text">加载中…</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{list.length === 0}}" class="state-card">
    <text class="state-text">暂无{{activeTab === 0 ? '待验收' : '已验收'}}任务</text>
  </view>

  <!-- 列表 -->
  <view wx:else class="card-list">
    <view wx:for="{{list}}" wx:key="id" class="task-card">
      <view class="task-rows">
        <view class="task-row">
          <text class="task-label">任务编号</text>
          <text class="task-val">{{item.taskNo || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">区域</text>
          <text class="task-val">{{item.areaName || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">令号</text>
          <text class="task-val">{{item.cmdNum || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">设施</text>
          <text class="task-val">{{item.actualProjectPointDetail && item.actualProjectPointDetail.facilityName || item.facilityName || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">故障等级</text>
          <text class="task-val">{{item.actualProjectPointDetail && item.actualProjectPointDetail.faultLevelName || item.faultLevel || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">严重程度</text>
          <text class="task-val">{{item.actualProjectPointDetail && item.actualProjectPointDetail.severityDegreeName || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">项点</text>
          <text class="task-val">{{item.actualProjectPointName || '-'}}</text>
        </view>
        <view class="task-row">
          <text class="task-label">故障类型</text>
          <text class="task-val">{{item.actualProjectPointDetail && item.actualProjectPointDetail.faultTypeName || item.faultTypeName || '-'}}</text>
        </view>
        <view class="task-row" wx:if="{{activeTab === 1}}">
          <text class="task-label">验收结果</text>
          <text class="task-val">{{item.acceptanceResultName || '-'}}</text>
        </view>
      </view>
      <view class="task-footer" bindtap="onDetail" data-id="{{item.id}}">
        <text class="task-detail">查看详情</text>
        <text class="task-chevron">›</text>
      </view>
    </view>
  </view>
</view>
