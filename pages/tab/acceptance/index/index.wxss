.page {
  min-height: 100%;
  padding: 0 0 40rpx;
  box-sizing: border-box;
  background-color: #f8f8f8;
}

/* ===== Tab ===== */
.tabs {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 0;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: #999999;
  padding-bottom: 20rpx;
}

.tab-active .tab-text {
  color: #7467ef;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: #7467ef;
  border-radius: 2rpx;
}

/* ===== 卡片列表 ===== */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 24rpx;
}

.task-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(116, 103, 239, 0.08);
}

.task-rows {
  padding: 28rpx 28rpx 8rpx;
}

.task-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 24rpx;
}

.task-label {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 400;
  color: #666666;
}

.task-val {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  text-align: right;
  word-break: break-all;
}

.task-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 28rpx 24rpx;
  border-top: 1px solid #eeeeee;
}

.task-detail {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.task-chevron {
  margin-left: 8rpx;
  font-size: 36rpx;
  font-weight: 400;
  color: #999999;
  line-height: 1;
}

/* ===== 状态颜色 ===== */
.st-green {
  color: #04ab38;
}

.st-orange {
  color: #f5a623;
}

.st-normal {
  color: #000000;
}

/* ===== 空/加载状态 ===== */
.state-card {
  margin: 24rpx 24rpx 0;
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.state-text {
  display: block;
  font-size: 30rpx;
  color: #333333;
}
