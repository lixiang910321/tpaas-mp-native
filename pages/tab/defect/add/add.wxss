.page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.content {
  height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.section {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.required {
  color: #ff5252;
  font-size: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.value-text {
  font-size: 28rpx;
  color: #333333;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  margin-left: 12rpx;
  font-size: 36rpx;
  color: #999999;
}

.remark-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
}

.add-icon {
  font-size: 64rpx;
  color: #999999;
}

.bottom-placeholder {
  height: 40rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.cancel-btn, .submit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  text-align: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666666;
}

.cancel-btn::after {
  border: none;
}

.submit-btn {
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
}

.submit-btn::after {
  border: none;
}
