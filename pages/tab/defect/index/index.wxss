.page {
  min-height: 100%;
  background-color: #f5f5f5;
  position: relative;
}

.list {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.item {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(90deg, #fff3e0 0%, #fff8e1 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.cmd-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.arrow {
  font-size: 36rpx;
  color: #999999;
}

.item-body {
  padding: 28rpx;
}

.row {
  display: flex;
  margin-bottom: 20rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.value.desc {
  flex: 1;
  word-break: break-all;
}

.value.status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.status.status-confirmed {
  background: #e3f2fd;
  color: #2196f3;
}

.status.status-completed {
  background: #e8f5e9;
  color: #4caf50;
}

.confirm-btn {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #f9f9f9;
}

.confirm-text {
  display: block;
  text-align: center;
  font-size: 30rpx;
  color: #7467ef;
  font-weight: 500;
}

.loading-more, .no-more {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 26rpx;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.add-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}
