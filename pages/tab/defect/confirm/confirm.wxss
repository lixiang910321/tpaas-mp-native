.page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.content {
  height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.info-card {
  background: #f8f9fa;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 1rpx solid #e9ecef;
}

.info-card-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #dee2e6;
}

.info-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

.info-value.readonly {
  color: #999999;
  background: transparent;
}

/* 描述行：纵向排列，标签在上值在下 */
.info-row-desc {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}
.info-row-desc .info-label {
  margin-right: 0;
}
.info-row-desc .info-value {
  text-align: left;
  word-break: break-all;
  line-height: 1.6;
  color: #999999;
}

.section {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.picker-value {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.value-text {
  font-size: 28rpx;
  color: #333333;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  margin-left: 12rpx;
  font-size: 36rpx;
  color: #999999;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
}

.add-icon {
  font-size: 64rpx;
  color: #999999;
}

.remark-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.bottom-placeholder {
  height: 40rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.cancel-btn, .submit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  line-height: 1;
  text-align: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666666;
}

.cancel-btn::after {
  border: none;
}

.submit-btn {
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
}

.submit-btn::after {
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.category-list {
  max-height: 60vh;
  padding: 24rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 30rpx;
  color: #333333;
}

.category-checked {
  font-size: 36rpx;
  color: #7467ef;
  font-weight: bold;
}

.result-list {
  padding: 24rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-name {
  font-size: 30rpx;
  color: #333333;
}

.result-checked {
  font-size: 36rpx;
  color: #7467ef;
  font-weight: bold;
}
