<view class="page">
  <scroll-view scroll-y class="content">
    <!-- 病害信息卡片（只读） -->
    <view class="info-card">
      <view class="info-card-header">
        <text class="info-card-title">病害信息</text>
      </view>
      <view class="info-row">
        <text class="info-label">令号</text>
        <text class="info-value readonly">{{diseaseDetail.cmdNum || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">接报日期</text>
        <text class="info-value readonly">{{reportDate || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">接报时间</text>
        <text class="info-value readonly">{{reportTimeOnly || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">来源</text>
        <text class="info-value readonly">{{diseaseDetail.source || '-'}}</text>
      </view>
      <view class="info-row info-row-desc">
        <text class="info-label">描述</text>
        <text class="info-value readonly">{{diseaseDetail.description || '-'}}</text>
    </view>
    </view>

    <!-- 区域选择 -->
    <view class="section" bindtap="onSelectArea">
      <view class="section-header">
        <text class="label">区域</text>
        <view class="picker-value">
          <text wx:if="{{selectedAreaName}}" class="value-text">{{selectedAreaName}}</text>
          <text wx:else class="placeholder-text">选择区域</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 计划项点选择 -->
    <view class="section" bindtap="onSelectProjectPoint">
      <view class="section-header">
        <text class="label">计划项点</text>
        <view class="picker-value">
          <text wx:if="{{form.planProjectPointName}}" class="value-text">{{form.planProjectPointName}}</text>
          <text wx:else class="placeholder-text">选择计划项点</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 施工类别 -->
    <view class="section" bindtap="onShowCategoryPicker">
      <view class="section-header">
        <text class="label">施工类别</text>
        <view class="picker-value">
          <text wx:if="{{form.constructionCategoryName}}" class="value-text">{{form.constructionCategoryName}}</text>
          <text wx:else class="placeholder-text">选择类别</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 确认结果 -->
    <view class="section" bindtap="onShowResultPicker">
      <view class="section-header">
        <text class="label">确认结果</text>
        <view class="picker-value">
          <text wx:if="{{form.confirmResult === 10}}" class="value-text">转班组</text>
          <text wx:elif="{{form.confirmResult === 20}}" class="value-text">现场处理</text>
          <text wx:else class="placeholder-text">选择处理方式</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 上传施工前照片 -->
    <view class="section">
      <view class="section-title">上传施工前照片</view>
      <view class="photo-list">
        <view wx:for="{{form.beforePhotoUrls}}" wx:key="index" class="photo-item">
          <image class="photo" src="{{item}}" mode="aspectFill" bindtap="previewPhoto" data-index="{{index}}" />
          <view class="photo-delete" bindtap="deletePhoto" data-index="{{index}}" catchtap="">
            <text class="delete-icon">×</text>
          </view>
        </view>
        <view wx:if="{{form.beforePhotoUrls.length < 9}}" class="photo-add" bindtap="choosePhoto">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>

    <!-- 确认备注 -->
    <view class="section">
      <view class="section-title">确认备注</view>
      <textarea class="remark-input" value="{{form.confirmRemark}}" bindinput="onRemarkInput" placeholder="输入其他内容" maxlength="500" />
    </view>

    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="cancel-btn" bindtap="goBack">取消</button>
    <button class="submit-btn" bindtap="submitConfirm" loading="{{submitting}}" disabled="{{submitting}}">提交</button>
  </view>

  <!-- 施工类别选择弹窗 -->
  <view wx:if="{{showCategoryPicker}}" class="modal-mask" bindtap="onHideCategoryPicker" catchtap="">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">选择施工类别</text>
        <text class="modal-close" bindtap="onHideCategoryPicker">×</text>
      </view>
      <scroll-view scroll-y class="category-list">
        <view wx:for="{{categoryList}}" wx:key="id" class="category-item" bindtap="selectCategory" data-item="{{item}}">
          <text class="category-name">{{item.name}}</text>
          <text wx:if="{{item.id === form.constructionCategoryId}}" class="category-checked">✓</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 确认结果选择弹窗 -->
  <view wx:if="{{showResultPicker}}" class="modal-mask" bindtap="onHideResultPicker" catchtap="">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">选择处理方式</text>
        <text class="modal-close" bindtap="onHideResultPicker">×</text>
      </view>
      <view class="result-list">
        <view class="result-item" bindtap="selectResult" data-result="{{10}}">
          <text class="result-name">转班组</text>
          <text wx:if="{{form.confirmResult === 10}}" class="result-checked">✓</text>
        </view>
        <view class="result-item" bindtap="selectResult" data-result="{{20}}">
          <text class="result-name">现场处理</text>
          <text wx:if="{{form.confirmResult === 20}}" class="result-checked">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>
