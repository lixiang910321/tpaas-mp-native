.page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.content {
  height: 100vh;
  padding-bottom: 160rpx;
}

.loading, .error {
  text-align: center;
  padding: 100rpx 32rpx;
  color: #999999;
  font-size: 28rpx;
}

.section {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

.value.status-pending {
  color: #ff9800;
  padding: 4rpx 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
}

.value.status-confirmed {
  color: #2196f3;
  padding: 4rpx 16rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 100%;
}

.tool-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.tool-name {
  font-size: 28rpx;
  color: #333333;
}

.tool-qty {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.confirm-btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #8b7cff 0%, #7467ef 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.confirm-btn::after {
  border: none;
}
